-- {{.Spec.ModuleName}}: Neovim plugin entry point.
-- Loaded on startup; keeps this file tiny and defers real work to the
-- lua/{{.Spec.ModuleName}}/ module so :source and :Lazy reload behave.

if vim.g.loaded_{{.Spec.ModuleIdent}} then
  return
end
vim.g.loaded_{{.Spec.ModuleIdent}} = 1

-- Augroup is declared here and reused by lua/{{.Spec.ModuleName}}/ modules.
-- clear = true is required — a stale augroup from a previous :source
-- would fire autocmds twice.
vim.api.nvim_create_augroup("{{.Spec.ModuleIdent}}", { clear = true })
